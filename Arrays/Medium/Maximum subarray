class Solution {
    public int maxSubArray(int[] nums) {

        int maxSum=Integer.MIN_VALUE;
        int sum=0;
        int temp=0;
        for(int i=0;i<nums.length;i++)
        {
            sum=sum+nums[i];
            if(maxSum<sum)
            {
                maxSum=sum;
            }
            if(0>sum)
            {
                sum=0;
            }
        }
        return maxSum;
    }
}
