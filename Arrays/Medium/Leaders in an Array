class Solution {
    static ArrayList<Integer> leaders(int arr[]) {
        ArrayList<Integer> ar=new ArrayList<Integer>();
        int high=0;
        for(int i=arr.length-1;i>=0;i--)
        {
            if(arr[i]>=high)
            {
                ar.add(arr[i]);
                high=arr[i];
            }
        }
        
        Collections.reverse(ar);
        return ar;
    }
}
