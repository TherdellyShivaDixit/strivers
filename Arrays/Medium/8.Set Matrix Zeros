class Solution {
    public void setZeroes(int[][] matrix) {

        boolean[] jIndex=new boolean[matrix.length];
        boolean[] iIndex=new boolean[matrix[0].length];
        
        for(int j=0;j<matrix.length;j++)
        {
            for(int i=0;i<matrix[0].length;i++)
            {
                if(matrix[j][i]==0)
                {
                    jIndex[j]=true;
                    iIndex[i]=true;
                }
            }
        }
        
        for(int j=0;j<matrix.length;j++)
        {
            for(int i=0;i<matrix[0].length;i++)
            {
                if(jIndex[j]||iIndex[i])
                {
                    matrix[j][i]=0;
                }
            }
        }
    }
}
