class Solution {
    public int findMaxConsecutiveOnes(int[] nums) {
        int max=0;
        int m=0;
        for(int i=0;i<nums.length;i++)
        {
            if(nums[i]==1)
            {
                m++;
                if(max<m)
                {
                    max=m;
                }
            }
            else
            {
                m=0;
            }
        }
        return max;
    }
}
