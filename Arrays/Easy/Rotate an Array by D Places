class Solution {
    public void rotate(int[] nums, int k) {
        k=k%nums.length;
        int[] temp=new int[k];

            for (int t=0,i=nums.length-k;i<nums.length;i++,t++)
            {
                temp[t]=nums[i];
            }
            for(int j=nums.length-1,m=nums.length-k-1;m>=0;m--,j--)
            {
                nums[j]=nums[m];
            }
            for(int n=0;n<k;n++)
            {
                nums[n]=temp[n];
            }
        
    }
}
