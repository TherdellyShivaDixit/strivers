class Solution {
    public int singleNumber(int[] nums) {

        ArrayList<Integer> ar=new ArrayList<Integer>();

        for(int i=0;i<nums.length;i++)
        {
            if(!ar.contains(nums[i]))
            {
                ar.add(nums[i]);                
            }
            else
            {
                ar.remove(Integer.valueOf(nums[i]));
            }
        }

        return ar.remove(0);
        
    }
}
