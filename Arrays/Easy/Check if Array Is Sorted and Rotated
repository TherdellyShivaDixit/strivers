class Solution {
    public boolean check(int[] nums) {
        
        int i=0;
        int count=0;
        while(i<nums.length-1)
        {
            if(nums[i]>nums[i+1])
            {
                count++;
            }
            i++;
        }
        if(count>0&&nums[0]<nums[nums.length-1])
        {
            return false;
        }
        else if(count<=1)
        {
            return true;
        }
        return false;
    }
}
