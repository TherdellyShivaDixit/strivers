class Solution {
    public int[] searchRange(int[] nums, int target) {
        
        int[] result={-1,-1};

        result[0]=find(nums,target,true);

        if(result[0]!=-1)
        {
            result[1]=find(nums,target,false);
        }
        return result;
    }
    private int find(int[] nums,int target, boolean isRight)
    {
        int left=0;
        int right=nums.length-1;
        int bound=-1;
        while(left<=right)
        {
            int mid=right+(left-right)/2;

            if(nums[mid]==target)
            {
                bound=mid;
                if(isRight)
                {
                    right=mid-1;
                }
                else
                {
                    left=mid+1;
                }
            }
            else if(nums[mid]<target)
            {
                left=mid+1;
            }
            else
            {
                right=mid-1;
            }

        }
        return bound;
    }
}
