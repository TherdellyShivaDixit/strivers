class Solution {
    public int findKRotation(int arr[]) {
        
        int rotation=0;
        int n=0;
        while(n<arr.length-2&&arr[n]<arr[n+1])
        {
            n++;
        }
        
        if(arr[0]>arr[arr.length-1])
        {
            return n+1;
        }
        else
        {
            return 0;
        }
    }
}
