class Solution {
    public int aggressiveCows(int[] stalls, int k) {
        
        Arrays.sort(stalls);
        int l=1;
        int r=stalls[stalls.length-1]-stalls[0];
        
        while(l<=r)
        {
            int mid=l+(r-l)/2; 
            
            if(check(stalls,mid,k))
            {
                l=mid+1;
            }
            else
            {
                r=mid-1;
            }

        }
            return r;        
    }
    
    private boolean check(int[] stalls,int dist,int k)
    {
        int cows=1;
        int last=stalls[0];
        
        for(int i=1;i<stalls.length;i++)
        {
            if(stalls[i]-last>=dist)
            {
                cows++;
                last=stalls[i];
            }
            if(cows>=k)
            {
                return true;
            }
        }
        return false;
    }
}
