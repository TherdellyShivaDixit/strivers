class Solution {
    public int mySqrt(int x) {
        
        long start=0;
        long end=x;

        while(start<=end)
        {
            long mid=start+(end-start)/2;
            long sq=mid*mid;
            long sq2=(mid+1)*(mid+1);

            if(sq<x&&x<sq2||sq==x)
            {
                return (int)mid;
            }
            
            if(sq<x)
            {
                start=mid+1;
            }
            else
            {
                end=mid-1;
            }
        }
        return 0;
    }
}
